# Track ONLY model files with LFS
models/**/*.safetensors filter=lfs diff=lfs merge=lfs -text
models/**/*.bin filter=lfs diff=lfs merge=lfs -text
models/**/*.gguf filter=lfs diff=lfs merge=lfs -text

# Track model configs and tokenizers (optional)
models/**/config.json filter=lfs diff=lfs merge=lfs -text
models/**/tokenizer.json filter=lfs diff=lfs merge=lfs -text
models/**/vocab.json filter=lfs diff=lfs merge=lfs -text
models/**/merges.txt filter=lfs diff=lfs merge=lfs -text
models/**/tokenizer_config.json filter=lfs diff=lfs merge=lfs -text
models/**/generation_config.json filter=lfs diff=lfs merge=lfs -text

# Explicitly mark source files as NOT LFS (just regular Git)
*.rs text diff -filter -merge
*.toml text diff -filter -merge
*.md text diff -filter -merge
*.txt text diff -filter -merge
Cargo.toml text diff -filter -merge
Cargo.lock text diff -filter -merge